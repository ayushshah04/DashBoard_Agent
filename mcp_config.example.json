{
  "mcpServers": {
    "workspace": {
      "enabled": true,
      "command": "python",
      "args": ["mcp_server_example.py"],
      "env": {
        "JARVIS_WORKSPACE": "workspace"
      }
    },
    "alpaca": {
      "enabled": false,
      "command": "uvx",
      "args": ["alpaca-mcp-server"],
      "env": {
        "ALPACA_API_KEY": "${ALPACA_API_KEY}",
        "ALPACA_SECRET_KEY": "${ALPACA_SECRET_KEY}",
        "ALPACA_PAPER_TRADE": "${ALPACA_PAPER_TRADE}",
        "ALPACA_BASE_URL": "${ALPACA_BASE_URL}",
        "ALPACA_TOOLSETS": "${ALPACA_TOOLSETS}"
      }
    },
    "newsdata": {
      "enabled": true,
      "command": "python",
      "args": ["newsdata_mcp_server.py"],
      "env": {
        "NEWSDATA_API_KEY": "${NEWSDATA_API_KEY}",
        "NEWSDATA_BASE_URL": "${NEWSDATA_BASE_URL}"
      }
    },
    "robinhood": {
      "enabled": true,
      "enabled_env": "ROBINHOOD_MCP_ENABLED",
      "transport": "streamable_http",
      "url": "${ROBINHOOD_MCP_URL}",
      "timeout": 30
    }
  }
}
